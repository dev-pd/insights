# ============================================================
# Required secrets - app fails to start without these
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Database
# Hosts use docker service names (postgres, redis) on the internal network.
# postgresql+asyncpg:// driver suffix is required for async SQLAlchemy.
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/feedback
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================
# Redis (cache + pub/sub for SSE)
# Pool sized for ~5-10 concurrent dashboard tabs (each holds 1-2
# long-lived SSE pubsub connections) + short-lived connection per
# /v1/stats poll / /v1/summary cache read.
# Bumped from 10 to 50 after a 100-item stress test exhausted the
# pool and hit MaxConnectionsError on /v1/summary + /v1/events.
# ============================================================
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5.0

# ============================================================
# LLM tuning
# ============================================================
LLM_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_SECONDS=1.0
LLM_CONCURRENCY_LIMIT=5

# ============================================================
# Input validation thresholds
# Inner business rules — feedback failing these is saved with status="skipped".
# ============================================================
FEEDBACK_MIN_LENGTH=10
FEEDBACK_MAX_LENGTH=5000
FEEDBACK_MIN_ALPHA_RATIO=0.4

# ============================================================
# Feedback API limits
# Outer wall — request body cap and default page size for the list endpoint.
# ============================================================
FEEDBACK_REQUEST_MAX_LENGTH=10000
FEEDBACK_LIST_DEFAULT_LIMIT=50

# ============================================================
# Stats dashboard
# Trend window for the daily sentiment chart (`stats_trend_days`).
# Theme window (`stats_theme_window_days`) scopes the top-themes chart to
# recent activity instead of all-time. The top-themes limit
# (`stats_top_themes_limit`) caps how many distinct themes the dashboard
# returns inside that window — the chart owns display, but the dashboard
# is for "what's hot this week", not exhaustive history.
# ============================================================
STATS_TREND_DAYS=14
STATS_THEME_WINDOW_DAYS=7
STATS_TOP_THEMES_LIMIT=10

# ============================================================
# AI summary widget (Phase 3.4)
# Cache TTL bounds how often the LLM is hit on natural traffic.
# Lookback window is what counts as "recent" for the summary.
# Max items caps prompt size; min items gates the LLM call (below the
# floor we return a static "not enough data" message instead of asking
# the model to summarize a single review).
# Max tokens caps the summary length — the prompt asks for 50-80 words
# which fits comfortably in 300 tokens.
# ============================================================
SUMMARY_CACHE_TTL_SECONDS=3600
SUMMARY_LOOKBACK_HOURS=24
SUMMARY_MAX_FEEDBACK_ITEMS=50
SUMMARY_MIN_FEEDBACK_ITEMS=3
SUMMARY_MAX_TOKENS=300

# ============================================================
# Celery (Phase 4 — async extraction + scheduled summary regen)
# Separate Redis logical DBs from the cache (db 0) so KEYS / FLUSHDB on
# one role doesn't pollute the others. Worker concurrency caps parallel
# tasks per worker — tune against Anthropic RPM/TPM limits.
# Soft / hard time limits give long tasks a SIGTERM-then-SIGKILL window
# so worker shutdown is predictable.
# ============================================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
# Lowered from 4 to 3 — see celery_worker_concurrency in config.py for
# the rate-limit rationale. Bump back to 4+ if your Anthropic tier
# supports a higher RPM.
CELERY_WORKER_CONCURRENCY=3
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=120
CELERY_TASK_TIME_LIMIT_SECONDS=180
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_BEAT_SUMMARY_CRON_MINUTE=0
# Retry budget for extraction tasks. Defaults absorb a ~5-10 minute
# rate-limit burst before marking a row FAILED. Drop to 3/60 to fail
# fast in dev; keep at 6/120 (or higher) under load.
CELERY_EXTRACT_MAX_RETRIES=6
CELERY_EXTRACT_RETRY_BACKOFF_MAX=120

# ============================================================
# Stress test endpoint (dev-grade load testing)
# Hard ceiling on how many synthetic feedbacks /v1/feedback/stress-test
# will dispatch per call. Set conservatively because each row burns an
# Anthropic API call on the worker side — bumping this means real $.
# ============================================================
STRESS_TEST_MAX_COUNT=200

# ============================================================
# SSE
# ============================================================
SSE_HEARTBEAT_INTERVAL_SECONDS=30
SSE_POLL_INTERVAL_SECONDS=1.0
SSE_MAX_STREAM_DURATION_MINUTES=5

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
